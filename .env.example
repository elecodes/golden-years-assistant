# Sentry Configuration
# Get your DSN from https://sentry.io
VITE_SENTRY_DSN=

# Environment (development, staging, production)
VITE_APP_ENV=development

# Medication Reminders Feature
# Set to 'true' to enable medication reminder notifications
# Default: false (disabled)
VITE_REMINDERS_ENABLED=false

# Voice Configuration (Amazon Polly)
# Set provider: 'polly' or 'browser' (default)
VITE_VOICE_PROVIDER=polly
# Voice: 'Joanna' (female neural) or 'Matthew' (male neural)
VITE_POLLY_VOICE=Joanna
# Polly API endpoint (from serverless deploy output)
VITE_POLLY_API_ENDPOINT=
VITE_POLLY_API_ENDPOINT=
